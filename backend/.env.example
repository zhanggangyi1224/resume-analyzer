# Core
APP_NAME=AI Resume Analyzer
APP_VERSION=1.0.0
API_PREFIX=/api/v1
MAX_PDF_SIZE_MB=10
CACHE_TTL_SECONDS=3600

# Optional cache (recommended in production)
REDIS_URL=redis://localhost:6379/0

# Optional AI enhancement
# AI_PROVIDER: auto | gemini | openai
AI_PROVIDER=auto

# Gemini API (works with keys like AIza...)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

# OpenAI-compatible API (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=45

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5500,http://localhost:8000
